<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>e-Postit Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root { --bg: #efeee9; --accent: #18181b; --active-green: #22c55e; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { background: var(--bg); color: #1a1a1b; font-family: sans-serif; margin: 0; overflow: hidden; height: 100vh; }

        /* HEADER FIXE AVEC BADGE INFOS */
        .fixed-header { 
            position: fixed; top: 0; left: 0; width: 100%; height: 95px; 
            background: var(--bg); z-index: 1000; padding: 10px 15px;
            border-bottom: 2px solid var(--accent);
            display: flex; justify-content: space-between; align-items: center;
        }

        #page-title { font-weight: 900; text-transform: uppercase; font-size: 1.1rem; font-style: italic; tracking-tighter; flex-shrink: 0; }

        #status-badge {
            background: #fff; border: 1px solid var(--accent);
            padding: 6px 10px; font-size: 8px; font-weight: 900;
            text-transform: uppercase; line-height: 1.5; min-width: 170px;
        }
        #status-badge div { display: flex; justify-content: space-between; gap: 10px; border-bottom: 1px solid #f0f0f0; }
        #status-badge div:last-child { border-bottom: none; }
        #status-badge span { color: var(--active-green); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 95px; text-align: right; }

        /* CONTENEUR DE PAGES */
        #viewport { 
            display: flex; width: 400vw; height: 100vh; 
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateX(-100vw); margin-top: 95px;
        }

        .page { width: 100vw; height: calc(100vh - 95px); overflow-y: auto; padding: 10px 20px 150px 20px; }

        /* ACCORDÉONS ROBUSTES (CSS ONLY) */
        .acc-item { border-bottom: 1px solid #ccc; }
        .acc-trigger { display: none; }
        .acc-label { display: flex; justify-content: space-between; padding: 20px 0; font-weight: 900; text-transform: uppercase; font-size: 0.8rem; cursor: pointer; color: var(--accent); }
        .acc-content { display: none; padding-bottom: 20px; }
        .acc-trigger:checked ~ .acc-content { display: block; }
        
        .acc-label span::before { content: '+'; font-size: 1.2rem; }
        .acc-trigger:checked ~ .acc-label span::before { content: '−'; }

        /* ELEMENTS UI */
        input, select, textarea { width: 100%; background: #fff; border: 2px solid var(--accent); padding: 12px; font-size: 16px; border-radius: 0; outline: none; margin-bottom: 8px; }
        .btn-black { background: var(--accent); color: white; font-weight: 900; text-transform: uppercase; font-size: 0.7rem; padding: 12px; border: none; cursor: pointer; width: 100%; }
        .list-item { display: flex; justify-content: space-between; align-items: center; background: white; padding: 10px; border: 1px solid #ddd; margin-bottom: 5px; font-size: 11px; font-weight: bold; }

        /* BARRE DE NAVIGATION */
        .tab-bar { height: 70px; background: white; border-top: 2px solid var(--accent); display: flex; justify-content: space-around; align-items: center; position: fixed; bottom: 0; width: 100%; z-index: 1000; }
        .tab-item { opacity: 0.3; display: flex; flex-direction: column; align-items: center; font-size: 10px; font-weight: 900; cursor: pointer; }
        .tab-item.active { opacity: 1; color: var(--accent); }

        #eink-sim { height: 100px; background: white; border: 3px solid #000; padding: 10px; font-family: monospace; margin-bottom: 15px; overflow-y: auto; font-size: 0.8rem; }
        .msg-bubble { background: #fff; border: 1px solid #e4e4e7; padding: 10px; margin-bottom: 8px; border-radius: 0 10px 10px 10px; font-size: 0.8rem; }

        #auth-screen { position: fixed; inset: 0; background: var(--bg); z-index: 9999; padding: 40px; display: flex; flex-direction: column; justify-content: center; }
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div id="auth-screen">
        <h1 class="text-4xl font-black mb-10 italic text-center tracking-tighter">e-POSTIT</h1>
        <input type="email" id="auth-email" placeholder="Email">
        <input type="password" id="auth-pass" placeholder="Mot de passe">
        <button onclick="login()" class="btn-black h-14 mt-4 text-lg">Connexion</button>
    </div>

    <div class="fixed-header">
        <h2 id="page-title">Direct</h2>
        <div id="status-badge">
            <div>Groupe: <span id="st-grp">-</span></div>
            <div>Display: <span id="st-dev">-</span></div>
            <div>PostIt: <span id="st-pos">-</span></div>
        </div>
    </div>

    <div id="viewport">
        <div class="page" id="p0">
            <div class="acc-item">
                <input type="checkbox" id="check-g" class="acc-trigger" checked>
                <label for="check-g" class="acc-label">1. Groupes <span></span></label>
                <div class="acc-content">
                    <div id="list-groups-del"></div>
                    <div class="flex gap-1"><input type="text" id="new-group-name" placeholder="Nom"><button onclick="createGroup()" class="btn-black w-24">CRÉER</button></div>
                </div>
            </div>

            <div class="acc-item">
                <input type="checkbox" id="check-d" class="acc-trigger">
                <label for="check-d" class="acc-label">2. Displays <span></span></label>
                <div class="acc-content">
                    <div id="list-devs-del"></div>
                    <input type="text" id="new-dev-mac" placeholder="Adresse MAC">
                    <div class="flex gap-1"><input type="text" id="new-dev-name" placeholder="Nom"><button onclick="addDevice()" class="btn-black w-24">CRÉER</button></div>
                </div>
            </div>

            <div class="acc-item">
                <input type="checkbox" id="check-p" class="acc-trigger">
                <label for="check-p" class="acc-label">3. Post-its <span></span></label>
                <div class="acc-content">
                    <div id="list-postits-del"></div>
                    <div class="flex gap-1"><input type="text" id="new-postit-name" placeholder="Nom"><button onclick="addPostit()" class="btn-black w-24">CRÉER</button></div>
                </div>
            </div>
            <button onclick="location.reload()" class="mt-10 opacity-30 text-[9px] uppercase font-black underline">Déconnexion</button>
        </div>

        <div class="page" id="p1">
            <div class="mb-4">
                <select id="sel-group" onchange="syncSelection('group', this.value)" class="font-black border-4 border-black h-14"></select>
                <div class="flex gap-2">
                    <select id="sel-dev" onchange="syncSelection('dev', this.value)" class="flex-1 font-bold text-xs h-10"></select>
                    <select id="sel-pos" onchange="refreshView()" class="flex-1 font-bold text-xs h-10"></select>
                </div>
            </div>
            <div id="eink-sim"></div>
            <div id="chat-history"></div>
            <div class="mt-4">
                <textarea id="msg-input" placeholder="Message..." class="h-20"></textarea>
                <button onclick="send()" class="btn-black h-14 text-base mt-2">Envoyer</button>
            </div>
        </div>

        <div class="page"><h2 class="mt-20 opacity-20 text-center font-black italic text-4xl uppercase">Archives</h2></div>

        <div class="page"><h2 class="mt-20 opacity-20 text-center font-black italic text-4xl uppercase">Membres</h2></div>
    </div>

    <nav class="tab-bar">
        <div class="tab-item" onclick="goToPage(0)"><span>⚙️</span><span>Params</span></div>
        <div class="tab-item active" onclick="goToPage(1)"><span>💬</span><span>Direct</span></div>
        <div class="tab-item" onclick="goToPage(2)"><span>📚</span><span>Archives</span></div>
        <div class="tab-item" onclick="goToPage(3)"><span>👥</span><span>Membres</span></div>
    </nav>

    <script>
        let socket, user, allMsgs = [], curP = 1, startX = 0;
        const titles = ["Paramètres", "Direct", "Archives", "Membres"];

        function goToPage(idx) {
            curP = idx;
            document.getElementById('viewport').style.transform = `translateX(-${idx * 100}vw)`;
            document.getElementById('page-title').innerText = titles[idx];
            document.querySelectorAll('.tab-item').forEach((t, i) => t.classList.toggle('active', i === idx));
        }

        window.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive: true});
        window.addEventListener('touchend', e => {
            let diff = startX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 100) {
                if (diff > 0 && curP < 3) goToPage(curP + 1);
                else if (diff < 0 && curP > 0) goToPage(curP - 1);
            }
        }, {passive: true});

        function updateBadge() {
            const g = document.getElementById('sel-group');
            const d = document.getElementById('sel-dev');
            const p = document.getElementById('sel-pos');
            document.getElementById('st-grp').innerText = g.options[g.selectedIndex]?.text || '-';
            document.getElementById('st-dev').innerText = d.options[d.selectedIndex]?.text || '-';
            document.getElementById('st-pos').innerText = p.options[p.selectedIndex]?.text || '-';
        }

        async function login() {
            const res = await fetch('/api/login', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({email: document.getElementById('auth-email').value, password: document.getElementById('auth-pass').value}) });
            if(res.ok) {
                const data = await res.json(); user = data.user;
                document.getElementById('auth-screen').classList.add('hidden');
                initApp();
            } else alert("Erreur d'authentification");
        }

        function initApp() {
            socket = io();
            socket.on('new-message', m => { allMsgs.unshift(m); refreshView(); });
            socket.on('history-data', h => { allMsgs = h; refreshView(); });
            loadGroups();
        }

        async function syncSelection(type, id) {
            if(type === 'group') { await loadGroupData(id); await loadGroups(); }
            else if(type === 'dev') { await loadPostits(id); await loadGroupData(document.getElementById('sel-group').value); }
            updateBadge();
        }

        async function loadGroups() {
            const res = await fetch('/api/groups');
            const groups = await res.json();
            const sel = document.getElementById('sel-group');
            if(groups.length > 0) {
                if(!sel.innerHTML) sel.innerHTML = groups.map(g => `<option value="${g._id}">${g.name}</option>`).join('');
                document.getElementById('list-groups-del').innerHTML = groups.map(g => `
                    <div class="list-item ${g._id === sel.value ? 'border-green-500 bg-green-50' : ''}">
                        <span>${g.name}</span>
                        <button onclick="deleteItem('group', '${g._id}')" class="text-red-500 font-bold px-2">×</button>
                    </div>`).join('');
                if(sel.value && !allMsgs.length) syncSelection('group', sel.value);
            }
            updateBadge();
        }

        async function loadGroupData(gid) {
            const res = await fetch(`/api/devices/${gid}`);
            const devs = await res.json();
            const dSel = document.getElementById('sel-dev');
            dSel.innerHTML = devs.map(d => `<option value="${d._id}">${d.name}</option>`).join('') || '<option value="">Aucun</option>';
            document.getElementById('list-devs-del').innerHTML = devs.map(d => `
                <div class="list-item ${d._id === dSel.value ? 'border-green-500 bg-green-50' : ''}">
                    <span>${d.name}</span>
                    <button onclick="deleteItem('dev', '${d._id}')" class="text-red-500 font-bold px-2">×</button>
                </div>`).join('');
            if(dSel.value) loadPostits(dSel.value);
            socket.emit('get-history', { groupId: gid });
        }

        async function loadPostits(devId) {
            const res = await fetch(`/api/postits/${devId}`);
            const postits = await res.json();
            const pSel = document.getElementById('sel-pos');
            pSel.innerHTML = postits.map(p => `<option value="${p._id}">${p.name}</option>`).join('') || '<option value="">Aucun</option>';
            document.getElementById('list-postits-del').innerHTML = postits.map(p => `
                <div class="list-item ${p._id === pSel.value ? 'border-green-500 bg-green-50' : ''}">
                    <span>${p.name}</span>
                    <button onclick="deleteItem('postit', '${p._id}')" class="text-red-500 font-bold px-2">×</button>
                </div>`).join('');
            refreshView();
            updateBadge();
        }

        function refreshView() {
            const devId = document.getElementById('sel-dev').value;
            const postitId = document.getElementById('sel-pos').value;
            const filtered = allMsgs.filter(m => m.deviceId === devId && m.postitId === postitId);
            document.getElementById('eink-sim').innerHTML = [...filtered].reverse().map(m => `<div>> ${m.content}</div>`).join('');
            document.getElementById('chat-history').innerHTML = filtered.map(m => `
                <div class="msg-bubble">
                    <div class="text-[9px] font-black opacity-30 uppercase">${m.senderName}</div>
                    ${m.content}
                </div>`).join('');
            updateBadge();
        }

        function send() {
            const txt = document.getElementById('msg-input');
            if(!txt.value.trim()) return;
            socket.emit('send-message', {
                groupId: document.getElementById('sel-group').value,
                deviceId: document.getElementById('sel-dev').value,
                postitId: document.getElementById('sel-pos').value,
                content: txt.value,
                senderName: user.name
            });
            txt.value = "";
        }

        async function deleteItem(t, id) {
            if(!confirm("Supprimer ?")) return;
            await fetch(`/api/${t==='group'?'groups':(t==='dev'?'devices':'postits')}/${id}`, { method: 'DELETE' });
            location.reload();
        }

        async function createGroup() {
            const n = document.getElementById('new-group-name').value;
            if(!n) return;
            await fetch('/api/groups', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({name: n}) });
            location.reload();
        }

        async function addDevice() {
            const gid = document.getElementById('sel-group').value;
            const n = document.getElementById('new-dev-name').value;
            const m = document.getElementById('new-dev-mac').value;
            if(!n || !gid) return;
            await fetch('/api/devices', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({groupId: gid, name: n, mac: m}) });
            location.reload();
        }

        async function addPostit() {
            const did = document.getElementById('sel-dev').value;
            const n = document.getElementById('new-postit-name').value;
            if(!n || !did) return;
            await fetch('/api/postits', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({deviceId: did, name: n}) });
            location.reload();
        }

        window.onload = async () => {
            const res = await fetch('/api/check-session');
            if(res.ok) {
                const data = await res.json(); user = data.user;
                document.getElementById('auth-screen').classList.add('hidden');
                initApp();
            }
        };
    </script>
</body>
</html>